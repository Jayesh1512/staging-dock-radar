# Claude API key for Step 2 article scoring
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ScraperAPI — Utilities → DJI Dock raw snapshot (LinkedIn by country)
SCRAPERAPI_KEY=your_scraperapi_key_here

# Optional: Cron email notifications
# Set SMTP credentials + recipient to get success/failure email on each scheduled run.
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_SMTP_FROM=
LATEST_ARTICLES_CRON_EMAIL_TO=
