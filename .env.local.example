# ── Supabase (Database) ──────────────────────────────────────────────────────
# Project URL from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co

# Service-role key (server-side only — NEVER expose to browser)
# Found at https://supabase.com/dashboard/project/_/settings/api → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── LLM Provider Selection ────────────────────────────────────────────────────
# Which model to use for Step 2 article scoring.
# Options: gemini (default) | openai | claude
LLM_PROVIDER=gemini

# ── API Keys (add the key for your selected provider) ─────────────────────────

# Gemini 2.5 Flash — PRIMARY (default)
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI GPT-4o — alternative
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude Sonnet 4.6 — alternative
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Step 1 ─────────────────────────────────────────────────────────────────────
# Collection uses Google News RSS — no API key required

# ── Pre-score filter (Step 2) ───────────────────────────────────────────────────
# Articles whose title contains any of these phrases are never sent to the LLM
# and never saved to scored_articles. Comma-separated. Example: Kansas City,Some Topic
# EXCLUDE_TITLE_KEYWORDS=Kansas City

# ── Slack Integration (Step 3 — Slack Internally button) ──────────────────────
# Bot token from https://api.slack.com/apps — needs chat:write scope
# Add the bot to your #dock-radar channel before use
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Channel ID (recommended) or name. Find the ID by right-clicking the channel
# in Slack → View channel details → scroll to bottom. Accepts: C0XYZABC or #dock-radar
SLACK_CHANNEL_ID=C0XYZABC123
NEWSAPI_KEY=340b2d62f0ee44869441fcaae451c8e7